{%- doc -%}
  Cart upsell row: single-variant uses Add (first variant); multi-variant uses Choose + modal.
  Price and quick-add sit on one row with space-between.

  @param {object} product - The product object
{%- enddoc -%}

{% style %}
  {% if request.visual_preview_mode %}
    product-card-link {
      width: 100%;
      min-width: 250px;
    }
  {% endif %}
{% endstyle %}

{% liquid
  assign has_quick_add = false
  if settings.quick_add and product.available
    assign has_quick_add = true
  endif

  assign has_mobile_quick_add = true
  if has_quick_add and settings.mobile_quick_add
    assign has_mobile_quick_add = true
  endif

  assign product_card_id = 'product-card-link-' | append: 'upsell' | append: '-' | append: product.id
  assign product_card_gap_value = 12

  assign variant_to_link = product.selected_or_first_available_variant

  if settings.transition_to_main_product
    assign featured_image = variant_to_link.featured_image
    if featured_image == blank
      assign featured_image = product.featured_media.preview_image
    endif

    if featured_image != blank
      assign featured_media_url = featured_image | image_url: width: 500
    endif
  endif

  assign onboarding = false
  if product.id == empty or product == blank
    assign onboarding = true
  endif

  assign upsell_has_multiple_variants = false
  if product.variants.size > 1
    assign upsell_has_multiple_variants = true
  endif
%}

{%- if settings.transition_to_main_product -%}
  <product-card-link
    data-product-id="{{ product.id }}"
    data-featured-media-url="{{ featured_media_url }}"
    data-product-transition="{{ settings.transition_to_main_product }}"
    {% if onboarding %}
      data-placeholder="true"
    {% endif %}
  >
{%- endif -%}
<product-card
  class="product-card upsell-card{% if upsell_has_multiple_variants %} upsell-card--multi-variant{% else %} upsell-card--add-only{% endif %}"
  data-product-id="{{ product.id }}"
  id="product-card-upsell-{{ product.id }}"
  data-product-transition="{{ settings.transition_to_main_product }}"
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
>
  <a
    id="{{ product_card_id | md5 }}"
    {% unless onboarding %}
      href="{{ variant_to_link.url }}"
    {% endunless %}
    class="product-card__link"
    ref="productCardLink"
  >
    <span class="visually-hidden">
      {{ product.title }}
    </span>
  </a>
  <div
    class="
      product-card__content
      layout-panel-flex
      layout-panel-flex--column
      product-grid__card
      spacing-style
      border-style
      gap-style
    "
    style="
      {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap' %}
      --quick-add-display: flex;
      --quick-add-mobile-display: flex;
      --quick-add-mobile-opacity: 1;
    "
  >
    <div class="upsell-content-row flex">
      <div class="upsell-media">
        {% if product.featured_media != blank %}
          {% assign media = product.selected_or_first_available_variant.featured_media | default: product.featured_media %}

          {% assign image_height = media.height %}
          {% assign image_height_2x = image_height | times: 2 %}
          {% assign image_height_3x = image_height | times: 3 %}

          {% capture image_srcset %}
            {{ media.preview_image | image_url: height: image_height }} 1x,
            {{ media.preview_image | image_url: height: image_height_2x }} 2x,
            {{ media.preview_image | image_url: height: image_height_3x }} 3x
          {% endcapture %}

          {{ media.preview_image
            | image_url: height: image_height
            | image_tag:
            class: 'upsell-media__image',
            srcset: image_srcset
          }}
        {% endif %}
      </div>
      <div class="upsell-details">
        <span class="upsell-title cart-items__title">{{ product.title }}</span>
        <div class="upsell-price-row">
          <div class="upsell-price-row__price">
            {% render 'price', product_resource: product, show_sale_price_first: true %}
          </div>
          <div class="upsell-price-row__action upsell-actions">
            {% render 'quick-add', product: product, section_id: 'cart-upsell', cart_upsell: true %}
          </div>
        </div>
      </div>
    </div>
  </div>
</product-card>
{%- if settings.transition_to_main_product -%}
  </product-card-link>
{%- endif -%}

{% stylesheet %}
  product-card-link,
  :not(product-card-link) product-card {
    width: 100%;
  }

  .product-card__placeholder-image svg {
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .product-card slideshow-arrows .slideshow-control {
      display: none;
    }
  }

  /*
   * Default quick-add is an overlay (absolute + opacity 0 until card hover).
   * Cart upsell sits in a tight row — restore in-flow layout and always show the visible control.
   */
  .upsell-card .quick-add {
    position: relative;
    inset: auto;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: nowrap;
    min-height: var(--minimum-touch-target);
    min-width: 0;
    pointer-events: auto;
    width: auto;
    z-index: 2;
  }

  .upsell-card--add-only .quick-add {
    max-width: min(100%, 12rem);
  }

  .upsell-card--multi-variant .quick-add {
    max-width: 100%;
  }

  .upsell-card .quick-add__button {
    position: static !important;
    inset: auto !important;
    right: auto !important;
    bottom: auto !important;
    opacity: 1 !important;
  }

  @media screen and (min-width: 750px) {
    .upsell-card .quick-add__button {
      opacity: 1 !important;
    }
  }

  .upsell-content-row {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--gap-sm);
    width: 100%;
  }

  .upsell-media {
    flex: 0 0 4.5rem;
    width: 4.5rem;
    overflow: hidden;
    align-self: flex-start;
  }

  .upsell-media__image,
  .upsell-card .upsell-media img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: inherit;
  }

  .upsell-details {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--gap-xs);
  }

  .upsell-card .upsell-title {
    line-height: 1.25;
    display: block;
    font-size: var(--font-size--sm);
  }

  .upsell-card .product-card__content {
    height: auto;
    isolation: isolate;
  }

  .upsell-price-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
    width: 100%;
    min-width: 0;
  }

  .upsell-price-row__price {
    flex: 1;
    min-width: 0;
    font-size: var(--font-size--sm);
  }

  .upsell-price-row__action {
    flex-shrink: 0;
  }

  .upsell-card .upsell-price-row__price [ref='priceContainer'] {
    font-size: var(--cart-font-size--sm);
    margin-top: 0;
  }

  .upsell-card--add-only .quick-add__product-form-component,
  .upsell-card--add-only .quick-add__product-form-component .shopify-product-form,
  .upsell-card--multi-variant .quick-add__product-form-component,
  .upsell-card--multi-variant .quick-add__product-form-component .shopify-product-form {
    height: auto;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    width: 100%;
  }

  /*
   * Add (single-variant) and Choose (multi-variant): primary button tokens (color scheme).
   * Choose has no add-to-cart-component in DOM — avoids theme [data-quick-add-button=choose] rule.
   */
  /*
   * quick-add.liquid .quick-add__button uses background: linear-gradient(var(--color-background)…)
   * and color: var(--color-foreground). That leaves a gradient layer and can pair white label text
   * with a light “card” foreground — same as white --color-primary-button-text → invisible.
   * Reset background to a solid primary fill and drive label text with currentColor.
   */
  .upsell-card--add-only .quick-add__button--add,
  .upsell-card--multi-variant .quick-add__button--choose {
    --button-border-width: var(--style-border-width-primary);

    display: flex !important;
    width: auto;
    min-width: 5.5rem;
    max-width: 100%;
    height: auto;
    min-height: unset;
    justify-content: center;
    align-items: center;
    right: auto;
    bottom: auto;
    margin: 0;
    padding-block: var(--button-padding-block);
    padding-inline: var(--button-padding-inline);
    border: none;
    border-radius: var(--style-border-radius-buttons-primary);
    background: var(--color-primary-button-text);
    background-image: none;
    color: var(--color-primary-button-background);
    box-shadow: inset 0 0 0 var(--button-border-width) var(--color-primary-button-border) !important;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    font-family: var(--button-font-family-primary);
    font-weight: var(--font-paragraph--weight);
    font-size: var(--font-size--xs);
    letter-spacing: var(--letter-spacing-sm);
    text-transform: var(--button-text-case-primary);
    transition: color var(--animation-speed) var(--animation-easing),
      box-shadow var(--animation-speed) var(--animation-easing),
      background var(--animation-speed) var(--animation-easing);
    overflow: visible !important;
  }

  .upsell-card xb-wishlist-button-collection {
    display: none !important;
  }

  .upsell-card--add-only .quick-add__button--add:hover,
  .upsell-card--multi-variant .quick-add__button--choose:hover {
    scale: 1;
    background: var(--color-primary-button-hover-text);
    background-image: none;
    color: var(--color-primary-button-hover-background);
    box-shadow: inset 0 0 0 var(--button-border-width) var(--color-primary-button-hover-border) !important;
  }

  .upsell-card--add-only .quick-add__button--add:active,
  .upsell-card--multi-variant .quick-add__button--choose:active {
    scale: 0.99;
  }

  .upsell-card--add-only .quick-add__button--add .add-to-cart-text,
  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-text {
    background: transparent !important;
    background-image: none !important;
    border: none;
    border-radius: 0;
    height: auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
    overflow: visible !important;
  }

  .upsell-card--add-only .quick-add__button--add .add-to-cart-text__content,
  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-text__content {
    grid-template-columns: 1fr;
  }

  /* Cart upsell Add uses icon_only_on_mobile; undo theme .is-visually-hidden-mobile so label shows */
  @media screen and (max-width: 749px) {
    .upsell-card--add-only .quick-add__button--add .add-to-cart-text__content.is-visually-hidden-mobile:not(:focus, :active) {
      position: static !important;
      overflow: visible !important;
      width: auto !important;
      height: auto !important;
      margin: 0 !important;
      padding: 0 !important;
      border: 0 !important;
      clip: auto !important;
      clip-path: none;
      word-wrap: normal !important;
    }
  }

  /*
   * Choose: quick-add defaults use grid 0fr + min-width:0 on the label stack, which clips
   * the label in the cart row (no hover expand). Size to the full string.
   */
  .upsell-card--multi-variant .quick-add__button--choose {
    width: max-content;
    max-width: 100%;
  }

  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-text__content {
    display: flex !important;
    align-items: center;
    justify-content: center;
    grid-template-columns: unset !important;
    overflow: visible;
    min-width: 0;
  }

  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-text__content > span {
    min-width: auto !important;
  }

  .upsell-card--add-only .quick-add__button--add .add-to-cart-text__content span span,
  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-text__content span span {
    opacity: 1;
    filter: none;
    translate: 0 0;
    padding: 0;
    color: currentColor;
    white-space: nowrap;
  }

  .upsell-card--add-only .quick-add__button--add .add-to-cart-icon,
  .upsell-card--multi-variant .quick-add__button--choose .add-to-cart-icon {
    display: none;
  }

  .upsell-card--add-only .quick-add__button--add:focus-visible,
  .upsell-card--multi-variant .quick-add__button--choose:focus-visible {
    outline: var(--focus-outline-width) solid var(--color-primary-button-text);
    outline-offset: var(--focus-outline-offset);
  }

  @media (forced-colors: active) {
    .upsell-card--add-only .quick-add__button--add,
    .upsell-card--multi-variant .quick-add__button--choose {
      background: ButtonText;
      color: ButtonFace;
      forced-color-adjust: none;
    }
  }

{% endstylesheet %}
