{%- comment -%} BreadcrumbList (product/collection) + WebSite SearchAction (homepage) structured data. {%- endcomment -%}
{%- assign base = shop.url -%}
{%- if template.name == 'product' and product != blank -%}
  {%- assign crumb_col = collection -%}
  {%- if crumb_col == blank -%}
    {%- for c in product.collections -%}
      {%- assign hh = c.handle -%}
      {%- unless hh == 'all' or hh == 'frontpage' or hh == 'best-sellers-1' or hh contains 'globofilter' or hh contains 'shop-by-color' or hh contains 'for-shopify' -%}
        {%- assign crumb_col = c -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ base | append: '/' | json }} }
{%- if crumb_col != blank -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ crumb_col.title | json }}, "item": {{ base | append: crumb_col.url | json }} }
    ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ base | append: product.url | json }} }
{%- else -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ base | append: product.url | json }} }
{%- endif -%}
  ]
}
</script>
{%- elsif template.name == 'collection' and collection != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ base | append: '/' | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ base | append: collection.url | json }} }
  ]
}
</script>
{%- elsif template.name == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": "{{ base }}/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ base }}/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": "{{ base }}/",
  {%- if shop.brand.logo != blank %}
  "logo": {{ shop.brand.logo | image_url: width: 500 | json }},
  {%- endif %}
  "sameAs": [
    "https://www.instagram.com/sipsiphooraydesign/",
    "https://www.tiktok.com/@sipsiphooraydesign",
    "https://www.facebook.com/sipsiphooraydesign/"
  ]
}
</script>
{%- endif -%}
