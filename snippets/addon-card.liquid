{%- doc -%}
  This snippet is used to render an addon card.
  It is used in the product block for addon products.

  @param {string} [card_layout_type] - Card layout type
  @param {object} product - The product object
  @param {object} [active_variant] - The active variant object
  @param {string} [render_text] - The render text
  @param {object} children - The children of the addon card
  @param {object} [block] - The block object
  @param {number} [product_card_gap] - The gap between the addon card children (overrides block settings)
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% style %}
  addon-card {
    display: block;
    width: 100%;
  }
{% endstyle %}

{% liquid
  assign has_quick_add = false
  if settings.quick_add and product.available
    assign has_quick_add = true
  endif

  assign has_mobile_quick_add = false
  if has_quick_add and settings.mobile_quick_add
    assign has_mobile_quick_add = true
  endif

  assign product_card_id = 'addon-card-link-' | append: block.id | append: '-' | append: product.id
  assign product_card_gap_value = product_card_gap | default: block_settings.product_card_gap

  # Logic to determine which variant URL to use (matching swatch selection logic)
  assign variant_to_link = product.selected_or_first_available_variant

  if active_variant != blank
    assign variant_to_link = active_variant
  endif

  if settings.transition_to_main_product
    assign featured_image = variant_to_link.featured_image
    if featured_image == blank
      assign featured_image = product.featured_media.preview_image
    endif

    if featured_image != blank
      assign featured_media_url = featured_image | image_url: width: 500
    endif
  endif

  assign onboarding = false
  if product.id == empty or product == blank
    assign onboarding = true
  endif
  
  # Check if product has variants
  assign has_variants = false
  if product.variants.size > 1
    assign has_variants = true
  endif
  
  assign selected_variant = active_variant | default: product.selected_or_first_available_variant
  
  # Get the image for the selected variant, fallback to product featured image
  assign variant_image = selected_variant.featured_image
  if variant_image == blank
    assign variant_image = product.featured_image
  endif
  
  # Get image dimensions and attributes
  assign image_width = variant_image.width | default: 500
  assign image_height = variant_image.height | default: 500
%}

<addon-card
  data-no-navigation
  class="addon-card {{ card_layout_type }} size-style"
  style="{% render 'size-style', settings: block_settings %}"
  data-product-id="{{ product.id }}"
  {% if active_variant != blank %}
    data-variant-id="{{ active_variant.id }}"
    data-variant-title="{{ active_variant.title }}"
    data-render-text="{{ render_text }}"
    data-variant-price="{{ active_variant.price | money_without_trailing_zeros }}"
    {% if active_variant.compare_at_price and active_variant.compare_at_price > active_variant.price %}
      data-variant-compare-price="{{ active_variant.compare_at_price | money_without_trailing_zeros }}"
    {% endif %}
  {% endif %}
  id="addon-card-{{ block.id }}"
  {% if settings.transition_to_main_product %}
    data-product-transition="true"
    data-featured-media-url="{{ featured_media_url }}"
  {% endif %}
  {{ block.shopify_attributes }}
  {% if onboarding %}
    data-placeholder="true"
  {% endif %}
>
  <div
    class="
      addon-card__content
      layout-panel-flex
      layout-panel-flex--column
      spacing-style
      border-style
      gap-style
      {% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }}{% endif %}
    "
    style="
      {% render 'border-override', settings: block_settings %}
      {% render 'layout-panel-style', settings: block_settings %}
      {% render 'spacing-style', settings: block_settings %}
      {% render 'gap-style', value: product_card_gap_value, name: 'product-card-gap' %}
      --quick-add-display: {% if has_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-display: {% if has_mobile_quick_add %}flex{% else %}none{% endif %};
      --quick-add-mobile-opacity: {% if has_mobile_quick_add %}1{% else %}0{% endif %};
      {% if block_settings.padding-inline-start > 0 %}--zoom-out-padding-inline-start: min(var(--padding-xs), {{ block_settings.padding-inline-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-inline-end > 0 %}--zoom-out-padding-inline-end: min(var(--padding-xs), {{ block_settings.padding-inline-end | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-start > 0 %}--zoom-out-padding-block-start: min(var(--padding-xs), {{ block_settings.padding-block-start | times: 0.7}}px);{% endif %}
      {% if block_settings.padding-block-end > 0 %}--zoom-out-padding-block-end: min(var(--padding-xs), {{ block_settings.padding-block-end | times: 0.7}}px);{% endif %}
    "
  >
    <div class="addon-flex flex">
        <div>
            {% liquid 
                assign property_name = 'addon-' | append: block.id
                assign element_id = 'addon-' | append: product.id | append: '-' | append: block.id
                assign product_form_id = 'BuyButtons-ProductForm-' | append: section.id
                assign disabled = false
                if selected_variant.available == false
                    assign disabled = true
                endif
            %}
            {% capture attributes %}
              data-price="{{ selected_variant.price }}"
              data-variant-id="{{ selected_variant.id }}"
            {% endcapture %}

            {% render 'checkbox',
                name: property_name,
                value: selected_variant.id,
                label: block_settings.checkbox_label,
                id: element_id,
                checked: false,
                events: '',
                disabled: disabled,
                required: false,
                formId: product_form_id,
                attributes: attributes
            %}
        </div>
        <div class="addon-image-wrapper">
          {% if variant_image != blank %}
            {{
              variant_image
              | image_url: width: 3840
              | image_tag:
                width: image_width,
                widths: '240, 352, 832, 1200, 1600, 1920, 2560, 3840',
                height: image_height,
                class: 'addon-product-image border-style',
                sizes: 'auto, (min-width: 750px) 100vw, 100vw',
                loading: 'eager',
                fetchpriority: 'high',
                alt: variant_image.alt | default: product.title
            }}
          {% else %}
            <div class="addon-image-placeholder">
              {{ 'product' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>
        <div>
            {{ children }}
            
            {% if has_variants %}
              <div class="addon-variant-wrapper">
                <select 
                  class="addon-variant-selector"
                  data-product-id="{{ product.id }}"
                  id="select-{{ block.id }}"
                >
                  {% for variant in product.variants %}
                    {% assign variant_image = variant.featured_image | default: product.featured_image %}
                    <option 
                      value="{{ variant.id }}"
                      {% if variant.id == selected_variant.id %}selected{% endif %}
                      data-available="{{ variant.available }}"
                      data-price="{{ variant.price }}"
                      {% if variant_image %}
                        data-image-url="{{ variant_image | image_url: width: 500 }}"
                      {% endif %}
                      {% if variant.compare_at_price and variant.compare_at_price > variant.price %}
                        data-compare-price="{{ variant.compare_at_price }}"
                      {% endif %}
                    >
                      {{ variant.title }}
                      {% unless variant.available %}
                        - {{ 'products.product.sold_out' | t }}
                      {% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% endif %}
            
            <span class="sold-out-addon" {% if selected_variant.available == true %} hidden{% endif %}>
              {{ 'content.product_badge_sold_out' | t }}
            </span>
        </div>
    </div>
  </div>
</addon-card>

{% stylesheet %}
    .addon-card {
        --checkbox-size: 20px;
        --checkbox-border-radius: 4px;
        --checkbox-border: 1.5px solid rgb(var(--color-foreground-rgb) / 1);
        --color-border-rgb: var(--color-foreground-rgb);
        --max-width--display-tight: auto;
        border: 1.5px solid var(--color-border);
        background: var(--color-background);
        cursor: pointer;
    } 

    .card-layout-addon-frequently {
      border-radius: 12px !important;
    }

    .addon-card:has(.checkbox__input:disabled) {
      background: rgb(var(--color-foreground-rgb) / .05);
      cursor: not-allowed;
    }

    .addon-card:has(.checkbox__input:checked) {
        border: 2px solid rgb(var(--color-foreground-rgb) / 1);
        box-shadow: 0 2px 8px rgba(var(--color-foreground-rgb) / 0.15);
    }

    .sold-out-addon {
      line-height: 1em;
      font-size: var(--font-size--2xs);
      font-style: italic;
      opacity: var(--opacity-60);
    }

    .addon-card .checkbox .icon-checkmark {
        min-width: var(--checkbox-size);
    }

    .addon-card .checkbox__label {
        min-width: unset;
    }

    .addon-card .checkbox__label-text {
        display: none;
    }

    .addon-card .contents {
        pointer-events: none;
    }

    .addon-card product-price .price:before {
        content: '+';
    }

    .addon-flex {
        display: flex;
        gap: var(--gap-sm);
        align-items: flex-start;
        width: 100%;
        min-width: 0;
        height: 100%;
    }

    .addon-flex > div:first-child {
        width: fit-content;
        align-self: center;
        flex-shrink: 0;
    }

    .addon-image-wrapper {
        width: 55px;
        min-width: 55px;
        flex-shrink: 0;
    }

    .addon-product-image {
        width: 100%;
        height: auto;
        display: block;
        border-radius: var(--border-radius-sm);
    }

    .addon-image-placeholder {
        width: 100%;
        height: auto;
        background: rgb(var(--color-foreground-rgb) / 0.05);
        border-radius: var(--border-radius-sm);
    }

    .addon-image-placeholder .placeholder-svg {
        width: 100%;
        height: auto;
        display: block;
    }

    .addon-flex > div:last-child {
        width: 100%;
        flex: 1 auto;
        display: flex;
        gap: var(--gap-2xs);
        flex-direction: column;
        justify-content: space-between;
        min-width: 0;
    }

    .addon-card .product-title-block > * {
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    /* Frequently-bought: don’t stretch .addon-flex to card height; rows size to content */
    .card-layout-addon-frequently .addon-flex {
      height: auto;
      min-height: 0;
      align-content: start;
    }

    @media (max-width: 749px) {
      .card-layout-addon-frequently .addon-flex > div:first-child {
        align-self: center;
      }
    }

    @media (min-width: 750px) {
      .card-layout-addon-frequently {
        height: 100%;
      }

      .card-layout-addon-frequently .addon-flex {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        gap: var(--gap-sm);
        align-items: start;
        width: 100%;
        min-width: 0;
      }

      /* Row 1 only with image: center checkbox in this row’s track (not across title/variant row) */
      .card-layout-addon-frequently .addon-flex > div:first-child {
          width: fit-content;
          flex-shrink: 0;
          grid-column: 1;
          grid-row: 1;
          align-self: center;
      }

      .card-layout-addon-frequently .addon-image-wrapper {
          grid-column: 2;
          grid-row: 1;
          width: 100%;
          min-width: 0;
          height: fit-content;
      }

      .card-layout-addon-frequently .addon-product-image {
          width: 100%;
          height: auto;
          display: block;
          border-radius: var(--border-radius-sm);
      }

      .card-layout-addon-frequently .addon-flex > div:last-child {
          grid-column: 2;
          grid-row: 2;
          width: 100%;
          flex: 0 1 auto;
          display: flex;
          gap: var(--gap-2xs);
          flex-direction: column;
          justify-content: flex-start;
          min-width: 0;
          align-self: start;
      }

      .card-layout-addon-frequently .addon-variant-wrapper {
          max-width: 100%;
      }
    }

    .addon-card .product-badges__badge {
        display: none;
    }
    
    /* Styles for variant selector */
    .addon-variant-wrapper {
      margin-top: var(--gap-2xs);
      max-width: 8rem;
    }
    
    .addon-variant-selector {
        width: 100%;
        padding: var(--gap-2xs) var(--gap-xs);
        font-size: var(--font-size--sm);
        border: 1px solid rgb(var(--color-border-rgb) / 0.2);
        border-radius: var(--border-radius-sm);
        background: var(--color-background);
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .addon-variant-selector:hover {
        border-color: rgb(var(--color-border-rgb) / 0.5);
    }
    
    .addon-variant-selector:focus {
        outline: none;
        border-color: rgb(var(--color-foreground-rgb) / 0.5);
        box-shadow: 0 0 0 2px rgb(var(--color-foreground-rgb) / 0.1);
    }

  @media screen and (max-width: 749px) {
    .addon-image-wrapper {
        width: 65px;
        min-width: 65px;
    }
    
    .addon-variant-selector {
        font-size: var(--font-size--xs);
        padding: var(--gap-3xs) var(--gap-2xs);
    }
  }
{% endstylesheet %}