{%- doc -%}
  Inline CSS variables for hotspots-flat aside section heading, card title, or price (prefixed section settings).
  @param section {object}
  @param scope {string} title | price | section_heading
{%- enddoc -%}
{% liquid
  assign s = section.settings
  if scope == 'price'
    assign preset = s.aside_product_price_type_preset | default: 'paragraph'
    assign color = s.aside_product_price_color
    assign font = s.aside_product_price_font
    assign font_size = s.aside_product_price_font_size
    assign line_height = s.aside_product_price_line_height
    assign letter_spacing = s.aside_product_price_letter_spacing
    assign text_case = s.aside_product_price_case
    assign text_wrap = s.aside_product_price_wrap
    assign enable_mobile_size = s.aside_product_price_enable_mobile_size
    assign mobile_font_size = s.aside_product_price_mobile_font_size
  elsif scope == 'section_heading'
    assign preset = s.aside_section_heading_type_preset | default: 'paragraph'
    assign color = s.aside_section_heading_color
    assign font = s.aside_section_heading_font
    assign font_size = s.aside_section_heading_font_size
    assign line_height = s.aside_section_heading_line_height
    assign letter_spacing = s.aside_section_heading_letter_spacing
    assign text_case = s.aside_section_heading_case
    assign text_wrap = s.aside_section_heading_wrap
    assign enable_mobile_size = s.aside_section_heading_enable_mobile_size
    assign mobile_font_size = s.aside_section_heading_mobile_font_size
  else
    assign preset = s.aside_product_title_type_preset | default: 'paragraph'
    assign color = s.aside_product_title_color
    assign font = s.aside_product_title_font
    assign font_size = s.aside_product_title_font_size
    assign line_height = s.aside_product_title_line_height
    assign letter_spacing = s.aside_product_title_letter_spacing
    assign text_case = s.aside_product_title_case
    assign text_wrap = s.aside_product_title_wrap
    assign enable_mobile_size = s.aside_product_title_enable_mobile_size
    assign mobile_font_size = s.aside_product_title_mobile_font_size
  endif

  if preset == blank or preset == 'rte'
    assign preset = 'paragraph'
  endif

  if preset == 'custom' and font == blank
    assign font = 'var(--font-body--family)'
  endif

  assign type = 'body'
  if preset == 'custom' and font_size != ''
    assign font_size_value = font_size | split: 'rem' | first | times: 1.0
    if font_size_value > 4.5
      assign type = 'display'
    elsif font_size_value > 3.5
      assign type = 'heading'
    else
      assign type = 'body'
    endif
  endif
%}
{%- capture variables -%}
  {%- if preset != 'rte' and color != blank and color != '' -%}
    --color: {{ color }};
  {%- endif -%}
  {%- if preset == 'custom' -%}
    {%- if font_size != blank -%}
      {%- liquid
        assign font_size_rem = font_size | split: 'rem' | first | times: 1.0
        assign fluid_size_cutoff_rem = 3.0
        if font_size_rem >= fluid_size_cutoff_rem
          assign target_viewport = 1400
          assign vw_value = font_size_rem | times: 16 | divided_by: target_viewport | times: 100
          assign scale_factor = font_size_rem | divided_by: fluid_size_cutoff_rem
          assign base_min_rem = 3.0
          assign scaling_bonus_rem = scale_factor | minus: 1 | times: 0.25
          assign dynamic_min_rem = base_min_rem | plus: scaling_bonus_rem
        endif
      -%}
      {%- if font_size_rem >= fluid_size_cutoff_rem -%}
        --font-size: clamp({{ dynamic_min_rem }}rem, {{ vw_value }}vw, {{ font_size }});
      {%- else -%}
        --font-size: {{ font_size }};
      {%- endif -%}
    {%- endif -%}
    --font-weight: {{ font | replace: 'family', 'weight' }};
    --font-family: {{ font }};
    --text-transform: {{ text_case }};
    --text-wrap: {{ text_wrap | default: 'pretty' }};
    {% if preset == 'custom' and font_size == blank %}
      --line-height--display: var(--line-height--display-{{ line_height }});
      --line-height--heading: var(--line-height--heading-{{ line_height }});
      --line-height--body: var(--line-height--body-{{ line_height }});
    {% else %}
      --line-height: var(--line-height--{{ type }}-{{ line_height }});
    {% endif %}
    --letter-spacing: var(--letter-spacing--{{ type }}-{{ letter_spacing }});
  {%- endif -%}
  {% if enable_mobile_size and mobile_font_size != blank %}
    --mobile-font-size: {{ mobile_font_size }};
  {% endif %}
{%- endcapture -%}
{{- variables | strip | strip_newlines -}}
