{%- doc -%}
  Product card for product-hotspots-flat aside (project-owned; mirrors resource-card product markup).
  Uses block.settings.hotspot_image when set; otherwise the same primary image logic as resource-card.
  @param {object} resource - Product
  @param {object} block - hotspot_flat block (hotspot_image)
  @param {string} [image_ratio] - adapt | portrait | square | landscape (section setting)
  @param {number} [image_width] - Default 1200
  @param {string} [image_sizes] - Default auto
  @param {boolean} [image_hover] - Secondary image on hover when using product images
  @param {object} [section] - Parent section (product title & price typography)
{%- enddoc -%}
{% liquid
  assign image_width = image_width | default: 1200
  assign widths = '240, 352, 832, 1200'
  assign image_sizes = image_sizes | default: 'auto'
  assign image_ratio = image_ratio | default: 'adapt'

  assign hotspot_override = block.settings.hotspot_image
  assign featured_image = resource.featured_media.preview_image | default: resource.featured_image

  assign base_for_adapt = hotspot_override
  if base_for_adapt == blank
    assign base_for_adapt = featured_image
  endif

  assign ratio = 1
  case image_ratio
    when 'landscape'
      assign ratio = '16 / 9'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'square'
      assign ratio = '1 / 1'
    when 'adapt'
      if base_for_adapt != blank
        assign ratio = base_for_adapt.aspect_ratio
      elsif resource.featured_image != blank
        assign ratio = resource.featured_image.aspect_ratio
      else
        assign ratio = 1
      endif
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif

  assign title_tt = 'h5'
  assign price_tt = 'h6'
  if section != blank
    assign title_tt = section.settings.aside_product_title_type_preset | default: 'h5'
    assign price_tt = section.settings.aside_product_price_type_preset | default: 'h6'
  endif
  if title_tt == blank or title_tt == 'rte'
    assign title_tt = 'h5'
  endif
  if price_tt == blank or price_tt == 'rte'
    assign price_tt = 'h6'
  endif
%}
{% liquid
  assign hotspot_pin_variant = blank
  assign hotspot_pin_needle = block.settings.hotspot_variant_name | default: '' | strip
  if hotspot_pin_needle != '' and resource != blank
    capture aside_pinned_id_str
      render 'hotspots-flat-pinned-variant-id', product: resource, block: block
    endcapture
    assign aside_pinned_id_str = aside_pinned_id_str | strip
    if aside_pinned_id_str != '' and resource != blank
      assign aside_pin_numeric_id = aside_pinned_id_str | plus: 0
      assign aside_pin_matches = resource.variants | where: 'id', aside_pin_numeric_id
      assign hotspot_pin_variant = aside_pin_matches.first
    endif
  endif

  assign variant_to_link = resource.selected_or_first_available_variant
  if hotspot_pin_variant != blank
    assign variant_to_link = hotspot_pin_variant
  endif

  if settings.transition_to_main_product
    assign featured_media_url = variant_to_link.featured_image | image_url: width: image_width
    if featured_media_url == blank
      assign featured_media_url = resource.featured_media.preview_image | image_url: width: image_width
    endif
  endif
%}
<div
  class="resource-card hotspots-flat-aside-product-card"
  data-resource-type="product"
>
  {%- if settings.transition_to_main_product -%}
    <product-card-link
      data-product-id="{{ resource.id }}"
      data-featured-media-url="{{ featured_media_url }}"
      data-product-transition="true"
      on:click="/handleViewTransition"
    >
  {%- endif -%}
  <div
    class="resource-card__media"
    style="--resource-card-aspect-ratio: {{ ratio }};"
    {% if settings.transition_to_main_product %}
      ref="cardGallery"
      data-view-transition-to-main-product
    {% endif %}
  >
    <a
      class="resource-card__link"
      href="{{ variant_to_link.url }}"
    >
      <span class="visually-hidden">
        {{ resource.title }}
      </span>
    </a>
    {%- if hotspot_override != blank -%}
      {% liquid
        assign ref_image_to_transition = ''
        if settings.transition_to_main_product
          assign ref_image_to_transition = 'imagesToTransition[]'
        endif
      %}
      {{
        hotspot_override
        | image_url: width: image_width
        | image_tag:
          loading: 'lazy',
          class: 'resource-card__image',
          widths: widths,
          sizes: image_sizes,
          ref: ref_image_to_transition,
          data-media-id: hotspot_override.id
      }}
    {%- elsif featured_image != blank -%}
      {% liquid
        assign primary_focal_point_style = ''
        if resource.media[0].presentation.focal_point != blank
          assign primary_focal_point_style = 'object-position: ' | append: resource.media[0].presentation.focal_point | append: ';'
        endif
        assign ref_image_to_transition = ''
        if settings.transition_to_main_product
          assign ref_image_to_transition = 'imagesToTransition[]'
        endif
      %}
      {{
        featured_image
        | image_url: width: image_width
        | image_tag:
          loading: 'lazy',
          class: 'resource-card__image',
          widths: widths,
          sizes: image_sizes,
          ref: ref_image_to_transition,
          data-media-id: featured_image.id,
          style: primary_focal_point_style
      }}
      {%- if image_hover and resource.media.size > 1 -%}
        {% liquid
          assign secondary_focal_point_style = ''
          if resource.media[1].presentation.focal_point != blank
            assign secondary_focal_point_style = 'object-position: ' | append: resource.media[1].presentation.focal_point | append: ';'
          endif
        %}
        {{
          resource.media[1]
          | image_url: width: image_width
          | image_tag:
            loading: 'lazy',
            class: 'resource-card__image resource-card__image--secondary',
            widths: widths,
            sizes: image_sizes,
            ref: ref_image_to_transition,
            data-media-id: resource.media[1].id,
            style: secondary_focal_point_style
        }}
      {%- endif -%}
    {%- else -%}
      <div
        aria-hidden="true"
        class="resource-card__image-placeholder"
      >
        {{- resource.title | truncate: 60 -}}
      </div>
    {%- endif -%}
  </div>
  {%- if settings.transition_to_main_product -%}
    </product-card-link>
  {%- endif -%}

  <div class="resource-card__content">
    {%- capture title_classes -%}
      resource-card__title text-block hotspots-aside-card__title
      {% if title_tt == 'custom' %}
        custom-typography
        {%- if section != blank and section.settings.aside_product_title_font_size != blank %} custom-font-size{% endif %}
      {% else %}
        {{ title_tt }}
      {% endif %}
      {% if section != blank and section.settings.aside_product_title_color != blank %} custom-color{% endif %}
    {%- endcapture -%}
    {%- capture price_classes -%}
      hotspots-aside-card__price
      {% if price_tt == 'custom' %}
        custom-typography
        {%- if section != blank and section.settings.aside_product_price_font_size != blank %} custom-font-size{% endif %}
      {% else %}
        {{ price_tt }}
      {% endif %}
      {%- if section != blank and section.settings.aside_product_price_color != blank %} custom-color{% endif %}
    {%- endcapture -%}
    {%- capture aside_price_style -%}
      {%- if section != blank -%}
        {%- render 'hotspots-aside-typography-style', section: section, scope: 'price' -%}
      {%- endif -%}
    {%- endcapture -%}
    {%- liquid
      assign aside_price_column_class = price_classes | strip | replace: '  ', ' '
      assign aside_price_column_style = aside_price_style | strip
    -%}
    <p
      class="{{ title_classes | strip | replace: '  ', ' ' }}"
      style="{% if section != blank %}{% render 'hotspots-aside-typography-style', section: section, scope: 'title' %}{% endif %}"
    >
      {{- resource.title -}}
    </p>
    {% render 'hotspots-flat-product-actions',
      product: resource,
      block: block,
      section: section,
      variant_context: 'aside',
      active_variant: hotspot_pin_variant,
      pin_lookup_completed: true,
      show_quick_add: resource.available,
      price_column_class: aside_price_column_class,
      price_column_style: aside_price_column_style
    %}
  </div>
</div>

{% stylesheet %}
  .hotspots-flat-aside-product-card .resource-card {
    --resource-card-secondary-image-opacity: 0;
    --resource-card-primary-image-opacity: calc(1 - var(--resource-card-secondary-image-opacity));

    display: flex;
    flex-direction: column;
    row-gap: var(--padding-xs);
    position: relative;
    text-decoration: none;
    height: 100%;
    opacity: 0;
    animation: fadeIn var(--animation-speed-medium) var(--animation-timing-fade-in) forwards;
  }

  .hotspots-flat-aside-product-card .resource-card__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hotspots-flat-aside-product-card .resource-card__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    color: var(--color-foreground);
    gap: var(--padding-sm);

    .price {
      font-weight: 500;
    }

    .hotspots-aside-card__price .price {
      font-weight: inherit;
    }

    .volume-pricing-note {
      display: block;
      margin-top: var(--padding-3xs);
      font-family: var(--font-body--family);
      font-weight: normal;
      font-size: min(0.85em, var(--font-paragraph--size));
      line-height: normal;
      letter-spacing: normal;
      text-transform: none;
      color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    }
  }

  /* Aspect box on media; images use contain so nothing is cropped */
  .hotspots-flat-aside-product-card .resource-card__media {
    aspect-ratio: var(--resource-card-aspect-ratio, auto);
    position: relative;
    overflow: hidden;
    border-radius: var(--resource-card-corner-radius);
    object-fit: contain;
  }

  .hotspots-flat-aside-product-card .resource-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    aspect-ratio: unset;
    border-radius: 0;
    opacity: var(--resource-card-primary-image-opacity);
  }

  .hotspots-flat-aside-product-card .resource-card__image--secondary {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    opacity: var(--resource-card-secondary-image-opacity);
    border-radius: 0;
  }

  .hotspots-flat-aside-product-card .resource-card__media:empty {
    display: none;
  }

  .hotspots-flat-aside-product-card .resource-card__image-placeholder {
    padding: var(--padding-sm);
    font-size: var(--font-size--lg);
    line-height: var(--line-height--display-loose);
    word-break: break-word;
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-5));
    aspect-ratio: unset;
    width: 100%;
    min-height: 8rem;
    border-radius: 0;
    color: var(--color-foreground);
  }

  .hotspots-flat-aside-product-card .resource-card__title {
    margin-block: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .hotspots-flat-aside-product-card .resource-card__title:not(.custom-typography) {
    line-height: 1.3;
  }

  .hotspots-flat-aside-product-card .resource-card__title.custom-typography {
    line-height: var(--line-height, inherit);
    display: block;
    -webkit-line-clamp: unset;
    -webkit-box-orient: unset;
  }

  .hotspots-flat-aside-product-card .resource-card__subtext {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    margin-block-start: 0;
  }

  .hotspots-flat-aside-product-card .resource-card__subtext.paragraph {
    font-size: var(--font-size--body-sm);
    line-height: var(--line-height--body-tight);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .hotspots-flat-aside-product-card .resource-card:has(.resource-card__image--secondary) {
    &:hover,
    &:focus {
      --resource-card-secondary-image-opacity: 1;
    }
  }
{% endstylesheet %}
