                "tab_row_dkjeXC": {
                  "type": "_tab-row",
                  "name": "Tab row",
                  "settings": {
                    "heading": "Shipping + Returns",
                    "content": "<p>Orders are handmade and ship from Louisiana. Most orders process in <strong>1–3 business days</strong>, with <strong>standard delivery </strong>taking <strong>3–5 business days</strong> after shipment.<br/><br/>Returns are accepted on non-personalized, unused items within 7 days of delivery. Items damaged in transit or defective will be replaced or refunded. Full details are available in our Policies.</p>",
                    "page": "",
                    "liquid": "",
                    "placement": "below-content",
                    "image_ratio": "adapt",
                    "open_by_default": false,
                    "type_preset": "rte",
