{% doc %}
  @prompt
    generate a text block, an inline text where first text should have customer name, 2nd column should have verified icon and Verified Buer text,\
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-verified-buyer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-verified-buyer-container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-verified-buyer-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    color: {{ block.settings.name_color }};
    font-weight: {{ block.settings.name_font_weight }};
    margin: 0;
  }

  .ai-verified-buyer-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.badge_spacing }}px;
  }

  .ai-verified-buyer-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-verified-buyer-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-verified-buyer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_font_size }}px;
    color: {{ block.settings.badge_text_color }};
    font-weight: {{ block.settings.badge_font_weight }};
    margin: 0;
  }
{% endstyle %}

<div class="ai-verified-buyer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-verified-buyer-container-{{ ai_gen_id }}">
    <span class="ai-verified-buyer-name-{{ ai_gen_id }}">{{ block.settings.customer_name }}</span>
    
    <div class="ai-verified-buyer-badge-{{ ai_gen_id }}">
      <span class="ai-verified-buyer-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
        </svg>
      </span>
      <span class="ai-verified-buyer-text-{{ ai_gen_id }}">{{ block.settings.verified_text }}</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Verified buyer",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Customer name",
      "default": "John Smith"
    },
    {
      "type": "text",
      "id": "verified_text",
      "label": "Verified text",
      "default": "Verified Buyer"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between elements",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "header",
      "content": "Customer name"
    },
    {
      "type": "range",
      "id": "name_font_size",
      "label": "Font size",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Text color",
      "default": "#2b2b2b"
    },
    {
      "type": "select",
      "id": "name_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Verified badge"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#008060"
    },
    {
      "type": "range",
      "id": "badge_spacing",
      "label": "Spacing",
      "min": 2,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text color",
      "default": "#2b2b2b"
    },
    {
      "type": "select",
      "id": "badge_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    }
  ],
  "presets": [
    {
      "name": "Verified buyer"
    }
  ],
  "tag": null
}
{% endschema %}