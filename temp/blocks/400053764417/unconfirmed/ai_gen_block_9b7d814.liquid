{% doc %}
  @prompt
    generate icons row with inline text, no need for color settings, should have font size on desktop mobile setting. should have column gap setting. between icon and text the gap should be 8px by default. the icons should be from image picker and should use liquid  {{
                block.settings.image
                | image_url: width: 2560
                | image_tag: width: width, height: block.settings.image.height, widths: widths, sizes: sizes, loading: 'lazy', alt: block.settings.image.alt, class: image_class
              }}, should have padding top and bottom setting for the block. and border top and border bottom checkbox and color width visible_if checked. should have setting whether to display icon+text as column on mobile , Liquid error (temp/ai_gen_block_0db0af7 line 89): expected widths to be a string, got Integer, the icon size should only in height. the width should be auto, the main row on mobile should have setting column upto 4 on mobile, on desktop just dpeends on column content width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icons-row-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    {% if block.settings.show_border_top %}
      border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.show_border_bottom %}
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-icons-row__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.column_gap }}px;
    justify-content: center;
    align-items: center;
  }

  .ai-icons-row__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-icons-row__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icons-row__icon-{{ ai_gen_id }} img {
    width: auto;
    height: {{ block.settings.icon_size }}px;
    object-fit: contain;
  }

  .ai-icons-row__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size_desktop }}px;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-icons-row__container-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
    }

    .ai-icons-row__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }

    {% if block.settings.mobile_column_layout %}
      .ai-icons-row__item-{{ ai_gen_id }} {
        flex-direction: column;
        text-align: center;
      }
    {% endif %}
  }
{% endstyle %}

<icons-row-{{ ai_gen_id }} class="ai-icons-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icons-row__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'icon_' | append: i
        assign text_key = 'text_' | append: i
        assign image = block.settings[image_key]
        assign text = block.settings[text_key]
      %}

      {% if image != blank or text != blank %}
        <div class="ai-icons-row__item-{{ ai_gen_id }}">
          {% if image != blank %}
            <div class="ai-icons-row__icon-{{ ai_gen_id }}">
              {% liquid
                assign height = block.settings.icon_size
                assign height_2x = height | times: 2
                assign widths = '50,100,150,200,300'
                assign sizes = height | append: 'px'
              %}
              {{
                image
                | image_url: width: 2560
                | image_tag: height: height, widths: widths, sizes: sizes, loading: 'lazy', alt: image.alt
              }}
            </div>
          {% endif %}

          {% if text != blank %}
            <div class="ai-icons-row__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</icons-row-{{ ai_gen_id }}>

<script>
  (function() {
    class IconsRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icons-row-{{ ai_gen_id }}', IconsRow{{ ai_gen_id }});
  })();
</script>

