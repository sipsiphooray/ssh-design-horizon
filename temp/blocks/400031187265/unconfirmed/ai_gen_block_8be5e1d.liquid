      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 80
    },
    {
      "type": "range",
      "id": "dot_vertical_position",
      "label": "Image dot vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 30
    },
    {
      "type": "range",
      "id": "dot_size",
      "label": "Dot size",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Image with text pointer"
    }
