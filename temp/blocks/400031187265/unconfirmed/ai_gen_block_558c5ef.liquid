{% doc %}
  @prompt
    image to the left, text to the right using richtext setting as value, and has line with circle to image as pointer. shoule be adjustable position top to bottom. the image should have height setting. the space should be justify between text and image, the image should render like this
    
              {{
                block.settings.image
                | image_url: width: 2560
                | image_tag: width: width, height: block.settings.image.height, widths: widths, sizes: sizes, loading: 'lazy', alt: block.settings.image.alt, class: image_class
              }}, no height setting needed, the height should always adapt to image ratio, can u keep horizontal on mobile, make the text area and size smaller on mobile.
    
    i should be able to place dot to any horizontal and vertical area of the image, the text and image should align justify between based on parent container. , i dont see the dot, the dot should always start in left side of text. the dot position would be adjustable, the dot position should be adjustable beneath the image area. the text should have width adjuster
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 2560' %}
{% assign sizes = '(min-width: 750px) 50vw, 100vw' %}

{% style %}
  .ai-image-text-pointer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-text-pointer__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-text-pointer__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 50%;
    max-width: 50%;
  }

  .ai-image-text-pointer__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-text-pointer__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-pointer__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    max-width: 500px;
  }

  .ai-image-text-pointer__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-pointer__pointer-area-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dot_bottom_position }}px;
    left: {{ block.settings.dot_horizontal_position }}%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .ai-image-text-pointer__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border-radius: 50%;
    position: relative;
    z-index: 3;
  }

  .ai-image-text-pointer__line-{{ ai_gen_id }} {
    position: absolute;
    height: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    top: 50%;
    left: 50%;
    transform-origin: left center;
    z-index: 2;
  }

  .ai-image-text-pointer__text-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 50%;
    max-width: 50%;
    width: {{ block.settings.text_width_percent }}%;
  }

  .ai-image-text-pointer__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-image-text-pointer__text-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-image-text-pointer__text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-image-text-pointer__text-dot-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    background-color: {{ block.settings.dot_color }};
    border-radius: 50%;
    left: 0;
    top: {{ block.settings.text_dot_position }}%;
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-pointer__container-{{ ai_gen_id }} {
      gap: 20px;
    }

    .ai-image-text-pointer__text-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-text-pointer__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }

    .ai-image-text-pointer__dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size | times: 0.8 }}px;
      height: {{ block.settings.dot_size | times: 0.8 }}px;
    }

    .ai-image-text-pointer__text-dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size | times: 0.8 }}px;
      height: {{ block.settings.dot_size | times: 0.8 }}px;
    }

    .ai-image-text-pointer__line-{{ ai_gen_id }} {
      height: {{ block.settings.line_thickness | times: 0.8 }}px;
    }
  }
{% endstyle %}

<image-text-pointer-{{ ai_gen_id }}
  class="ai-image-text-pointer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-pointer__container-{{ ai_gen_id }}">
    <div class="ai-image-text-pointer__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        {{
          block.settings.image
          | image_url: width: 2560
          | image_tag: widths: widths, sizes: sizes, loading: 'lazy', alt: block.settings.image.alt, class: 'ai-image-text-pointer__image-' | append: ai_gen_id
        }}
        <div class="ai-image-text-pointer__pointer-area-{{ ai_gen_id }}">
          <div class="ai-image-text-pointer__dot-{{ ai_gen_id }}"></div>
          <div class="ai-image-text-pointer__line-{{ ai_gen_id }}"></div>
        </div>
      {% else %}
        <div class="ai-image-text-pointer__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text-pointer__empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-image-text-pointer__text-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-pointer__text-dot-{{ ai_gen_id }}"></div>
      {% if block.settings.text != blank %}
        <div class="ai-image-text-pointer__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% else %}
        <div class="ai-image-text-pointer__text-{{ ai_gen_id }}">
          <p>Add your text content here to describe the image or highlight key features.</p>
        </div>
      {% endif %}
    </div>
  </div>
</image-text-pointer-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextPointer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.updateLinePosition();
        window.addEventListener('resize', () => this.updateLinePosition());
      }

      updateLinePosition() {
        const line = this.querySelector('.ai-image-text-pointer__line-{{ ai_gen_id }}');
        const pointerArea = this.querySelector('.ai-image-text-pointer__pointer-area-{{ ai_gen_id }}');
        const textDot = this.querySelector('.ai-image-text-pointer__text-dot-{{ ai_gen_id }}');

        if (!line || !pointerArea || !textDot) return;

        const pointerRect = pointerArea.getBoundingClientRect();
        const textDotRect = textDot.getBoundingClientRect();

        const deltaX = textDotRect.left - pointerRect.left;
        const deltaY = textDotRect.top - pointerRect.top;

        const length = Math.sqrt(deltaX * deltaX + deltaY * deltaY);
        const angle = Math.atan2(deltaY, deltaX) * (180 / Math.PI);

        line.style.width = length + 'px';
        line.style.transform = 'translateY(-50%) rotate(' + angle + 'deg)';
      }
    }

    customElements.define('image-text-pointer-{{ ai_gen_id }}', ImageTextPointer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image with text pointer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Text"
