{% liquid
  assign s = section.settings
%}

{% capture children %}
  <div
    class="timeline-icons"
    style="
      --timeline-marker-size: {{ s.marker_size }}px;
      --timeline-icon-size: {{ s.icon_size }}px;
      --timeline-line-thickness: {{ s.line_thickness }}px;
      --timeline-line-color: {{ s.line_color.red }}, {{ s.line_color.green }}, {{ s.line_color.blue }};
      --timeline-marker-bg: {{ s.marker_background.red }}, {{ s.marker_background.green }}, {{ s.marker_background.blue }};
      --timeline-marker-border-color: {{ s.marker_border_color.red }}, {{ s.marker_border_color.green }}, {{ s.marker_border_color.blue }};
      --timeline-marker-border-width: {{ s.marker_border_width }}px;
    "
  >
    {% if s.heading != blank %}
      <h2 class="timeline-icons__heading">
        {{ s.heading | escape }}
      </h2>
    {% endif %}

    {% if s.subheading != blank %}
      <div class="timeline-icons__subheading rte">
        {{ s.subheading }}
      </div>
    {% endif %}

    <div class="timeline-icons__steps" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign bs = block.settings
        %}

        <div class="timeline-icons__step" role="listitem" {{ block.shopify_attributes }}>
          <div class="timeline-icons__marker">
            <span class="timeline-icons__icon">
              {% render 'icon-or-image',
                icon: bs.icon,
                image_upload: bs.image_upload,
                width: s.icon_size,
                class_name: 'timeline-icons__icon-media'
              %}
            </span>
          </div>

          {% if bs.heading != blank %}
            <h3 class="timeline-icons__step-heading">
              {{ bs.heading | escape }}
            </h3>
          {% endif %}

          {% if bs.text != blank %}
            <div class="timeline-icons__step-text rte">
              {{ bs.text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% endcapture %}

{% render 'section', section: section, children: children %}

{% stylesheet %}
  .timeline-icons {
    --timeline-marker-size: 56px;
    --timeline-icon-size: 22px;
    --timeline-line-thickness: 10px;
    --timeline-line-color: 47, 47, 47;
    --timeline-marker-bg: 243, 238, 234;
    --timeline-marker-border-color: 47, 47, 47;
    --timeline-marker-border-width: 0px;

    display: grid;
    gap: var(--gap-xl);
  }

  .timeline-icons__heading {
    margin: 0;
    text-align: center;
    max-width: 50rem;
    margin-inline: auto;
  }

  .timeline-icons__subheading {
    text-align: center;
    opacity: var(--opacity-subdued-text);
    max-width: 50rem;
    margin-inline: auto;
  }

  .timeline-icons__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--timeline-columns, 3), minmax(0, 1fr));
    gap: clamp(16px, 4vw, 64px);
    align-items: start;
  }

  .timeline-icons__steps:before {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    right: 0;
    top: calc(var(--timeline-marker-size) / 2);
    height: var(--timeline-line-thickness);
    background: rgb(var(--timeline-line-color));
    border-radius: 999px;
    width: 73%;
  }

  .timeline-icons__step {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: var(--gap-sm);
    text-align: center;
  }

  .timeline-icons__marker {
    width: var(--timeline-marker-size);
    height: var(--timeline-marker-size);
    border-radius: 999px;
    background: rgb(var(--timeline-marker-bg));
    border: var(--timeline-marker-border-width) solid rgb(var(--timeline-marker-border-color));
    display: grid;
    place-items: center;
  }

  .timeline-icons__icon,
  .timeline-icons__icon-media {
    display: block;
  }

  .timeline-icons__icon-media {
    width: var(--timeline-icon-size);
    height: var(--timeline-icon-size);
  }

  .timeline-icons__step-heading {
    margin: 0;
    font-size: var(--font-size--xl);
  }

  @media (max-width: 749px) {
    .timeline-icons__steps {
      grid-template-columns: 1fr;
      gap: var(--gap-2xl);
    }

    .timeline-icons__steps::before {
      height: 68% !important;
      width: var(--timeline-line-thickness);
      left: calc(var(--timeline-marker-size) / 2);
    }

    .timeline-icons__step {
      display: grid;
      grid-template-columns: var(--timeline-marker-size) 1fr;
      grid-template-areas:
        "marker heading"
        "marker text";
    }

    .timeline-icons__marker {
      grid-area: marker;
      --timeline-marker-size: 32px !important;
    }

    .timeline-icons__step-heading {
      grid-area: heading;
    }

    .timeline-icons__step-text {
      grid-area: text;
    }


    .timeline-icons__step-heading,
    .timeline-icons__step-text {
      text-align: left;
      display: block;
      width: 100%;
    }

    .timeline-icons__step {
      grid-template-columns: var(--timeline-marker-size) 1fr;
    }
    .timeline-icons__icon-media {
      width: auto !important;
      height: 16px !important;
    }
  }
{% endstylesheet %}

{% schema %}
