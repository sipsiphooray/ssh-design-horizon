{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icons-row-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    {% if block.settings.show_border_top %}
      border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.show_border_bottom %}
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-icons-row__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, minmax(0, auto));
    column-gap: {{ block.settings.column_gap }}px;
    row-gap: {{ block.settings.row_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
  }

  .ai-icons-row__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_gap }}px;
    /* Ensure desktop item alignment follows main setting */
    justify-content: {{ block.settings.alignment }};
  }

  .ai-icons-row__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .ai-icons-row__icon-{{ ai_gen_id }} img {
    width: auto;
    height: {{ block.settings.icon_size }}px;
    display: block;
  }

  .ai-icons-row__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size_desktop }}px;
    line-height: 1.2;
  }

  .ai-icons-row__text-{{ ai_gen_id }} p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-icons-row__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
      column-gap: {{ block.settings.mobile_column_gap }}px;
      row-gap: {{ block.settings.mobile_row_gap }}px;
      justify-content: {{ block.settings.mobile_alignment }};
    }

    .ai-icons-row__item-{{ ai_gen_id }} {
      /* This ensures the whole item block moves left/center/right in the grid cell */
      justify-content: {{ block.settings.mobile_alignment }};
      
      {% if block.settings.mobile_column_layout %}
        flex-direction: column;
        /* Horizontal alignment for column layout */
        align-items: {{ block.settings.mobile_alignment }};
        text-align: {% if block.settings.mobile_alignment == 'flex-start' %}left{% elsif block.settings.mobile_alignment == 'flex-end' %}right{% else %}center{% endif %};
      {% else %}
        /* Vertical alignment for side-by-side layout */
        align-items: center;
      {% endif %}
    }

    {% if block.settings.enable_padding_inline_mobile %}
      .ai-icons-row-{{ ai_gen_id }} {
        padding-left: {{ block.settings.mobile_padding_left }}px;
        padding-right: {{ block.settings.mobile_padding_right }}px;
      }
    {% endif %}

    .ai-icons-row__icon-{{ ai_gen_id }} img {
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-icons-row__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<icons-row-{{ ai_gen_id }} class="ai-icons-row ai-icons-row-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icons-row__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'icon_' | append: i
        assign text_key = 'text_' | append: i
        assign image = block.settings[image_key]
        assign text = block.settings[text_key]
      %}

      {% if image != blank or text != blank %}
        <div class="ai-icons-row__item-{{ ai_gen_id }}">
          {% if image != blank %}
            <div class="ai-icons-row__icon-{{ ai_gen_id }}">
              {% liquid
                assign height = block.settings.icon_size
                assign widths = '100, 200, 300'
                assign sizes = height | append: 'px'
              %}
              {{
                image
                | image_url: width: 600
                | image_tag: 
                  height: height, 
                  widths: widths, 
                  sizes: sizes, 
                  loading: 'lazy', 
                  alt: image.alt,
                  class: 'icon-img'
              }}
            </div>
          {% endif %}

          {% if text != blank %}
            <div class="ai-icons-row__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</icons-row-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Icons row",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    { "type": "image_picker", "id": "icon_1", "label": "Icon 1" },
    { "type": "richtext", "id": "text_1", "label": "Text 1", "default": "<p>Feature 1</p>" },
    { "type": "image_picker", "id": "icon_2", "label": "Icon 2" },
    { "type": "richtext", "id": "text_2", "label": "Text 2", "default": "<p>Feature 2</p>" },
    { "type": "image_picker", "id": "icon_3", "label": "Icon 3" },
    { "type": "richtext", "id": "text_3", "label": "Text 3", "default": "<p>Feature 3</p>" },
    { "type": "image_picker", "id": "icon_4", "label": "Icon 4" },
    { "type": "richtext", "id": "text_4", "label": "Text 4", "default": "<p>Feature 4</p>" },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ]
    },
    { "type": "range", "id": "icon_size", "label": "Icon height", "min": 10, "max": 100, "step": 1, "unit": "px", "default": 32 },
    { "type": "range", "id": "icon_gap", "label": "Gap between Icon & Text", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "column_gap", "label": "Column gap", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 30 },
    { "type": "range", "id": "row_gap", "label": "Row gap", "min": 0, "max": 100, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "desktop_width_percent", "label": "Desktop width", "min": 10, "max": 100, "step": 5, "unit": "%", "default": 100 },
    {
      "type": "header",
      "content": "Mobile Layout"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile Alignment",
      "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "mobile_column_layout",
      "label": "Stack icon above text",
      "default": false
    },
    { "type": "range", "id": "icon_size_mobile", "label": "Icon height mobile", "min": 10, "max": 80, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "mobile_column_gap", "label": "Column gap mobile", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 15 },
    { "type": "range", "id": "mobile_row_gap", "label": "Row gap mobile", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "header",
      "content": "Typography"
    },
    { "type": "range", "id": "font_size_desktop", "label": "Desktop font size", "min": 10, "max": 40, "step": 1, "unit": "px", "default": 14 },
    { "type": "range", "id": "font_size_mobile", "label": "Mobile font size", "min": 10, "max": 30, "step": 1, "unit": "px", "default": 12 },
    {
      "type": "header",
      "content": "Spacing & Borders"
    },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 5, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "default": 20 },
    { "type": "checkbox", "id": "enable_padding_inline_mobile", "label": "Custom mobile inline padding", "default": false },
    { "type": "range", "id": "mobile_padding_left", "label": "Padding left mobile", "min": 0, "max": 50, "default": 0 },
    { "type": "range", "id": "mobile_padding_right", "label": "Padding right mobile", "min": 0, "max": 50, "default": 0 },
    { "type": "checkbox", "id": "show_border_top", "label": "Show top border", "default": false },
    { "type": "checkbox", "id": "show_border_bottom", "label": "Show bottom border", "default": false },
    { "type": "range", "id": "border_width", "label": "Border width", "min": 1, "max": 10, "default": 1 },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#e5e5e5" }
  ],
  "presets": [{ "name": "Icons row" }]
}
{% endschema %}