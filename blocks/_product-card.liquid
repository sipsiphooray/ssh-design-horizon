{%- doc -%}
  Renders the Horizon product card stack (static gallery + nested blocks).

  @param {string} [product_view_context] - Context value passed through to the card snippet.
  @param {string} [discount_label] - The discount label
  @param {string} [discount_background] - The discount background color
  @param {string} [discount_color_text] - The discount text color
  @param {object} [active_variant] - Pinned variant (e.g. curated-variant-list). Drives card_initial_variant when set.
{%- enddoc -%}

{% liquid
  assign product = closest.product
  assign card_initial_variant = blank
  assign card_title_suffix = blank

  if active_variant != blank
    assign card_initial_variant = active_variant
  elsif product != blank and product.has_only_default_variant == false and collection != blank and collection.metafields.custom.variants_to_render != blank
    assign vtr_meta = collection.metafields.custom.variants_to_render
    assign vtr_val = vtr_meta.value
    if vtr_val != blank
      assign vtr_matched = blank
      assign matched_needle = blank
      if vtr_meta.type contains 'list'
        for token in vtr_val
          assign needle = token.value | default: token
          if needle == blank
            continue
          endif
          for v in product.variants
            if v.title contains needle
              assign vtr_matched = v
              assign matched_needle = needle
              break
            endif
          endfor
          if vtr_matched != blank
            break
          endif
        endfor
      else
        assign needle = vtr_val
        if needle != blank
          for v in product.variants
            if v.title contains needle
              assign vtr_matched = v
              assign matched_needle = needle
              break
            endif
          endfor
        endif
      endif
      if vtr_matched != blank
        assign card_initial_variant = vtr_matched
        assign card_title_suffix = matched_needle
      endif
    endif
  endif
-%}

{% capture children %}
  {% content_for 'block',
    type: '_product-card-gallery',
    id: 'product-card-gallery',
    discount_label: discount_label,
    discount_background: discount_background,
    discount_color_text: discount_color_text,
    product: product,
    pinned_variant: card_initial_variant
  %}
  {% content_for 'blocks', closest.product: product %}
{% endcapture %}

{% render 'product-card',
  children: children,
  product: product,
  product_view_context: product_view_context,
  active_variant: active_variant,
  initial_variant: card_initial_variant,
  title_suffix: card_title_suffix
%}
{% render 'quantity-selector-styles' %}
{% render 'buy-buttons-styles' %}
{% render 'gift-card-recipient-form-styles' %}
{% render 'quick-add-styles' %}
{% render 'quick-add-modal-styles' %}
{% render 'swatch-styles' %}
{% render 'variant-picker-styles' %}
{% render 'product-badges-styles' %}

{% schema %}
{
  "name": "t:names.product_card",
  "blocks": [
    {
      "type": "_product-card-group"
    },
    {
      "type": "text"
    },
    {
      "type": "image"
    },
    {
      "type": "buy-buttons"
    },
    {
      "type": "price"
    },
    {
      "type": "review"
    },
    {
      "type": "sku"
    },
    {
      "type": "swatches"
    },
    {
      "type": "product-title"
    },
    {
      "type": "custom-liquid"
    },
    {
      "type": "@app"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_card"
    },
    {
      "type": "range",
      "id": "product_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
