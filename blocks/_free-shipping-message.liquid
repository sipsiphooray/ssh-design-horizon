{%- liquid
  assign block_settings = block.settings
  assign v = closest.product.selected_or_first_available_variant
  assign threshold_major = block_settings.threshold_amount | default: 75
  assign threshold_cents = threshold_major | times: 100

  assign fsm_color_style = ''
  if block_settings.before_custom_color and block_settings.before_text_color != blank
    assign fsm_color_style = fsm_color_style | append: ' --fsm-before-custom-color: ' | append: block_settings.before_text_color | append: ';'
  endif
  if block_settings.success_custom_color and block_settings.success_text_color != blank
    assign fsm_color_style = fsm_color_style | append: ' --fsm-success-custom-color: ' | append: block_settings.success_text_color | append: ';'
  endif
-%}

<free-shipping-message
  class="free-shipping-message spacing-style text-block text-block--{{ block.id }}"
  style="{% render 'spacing-style', settings: block_settings %}{{ fsm_color_style }}"
  data-threshold-cents="{{ threshold_cents }}"
  data-variant-unit-cents="{{ v.price }}"
  data-product-id="{{ closest.product.id }}"
  {{ block.shopify_attributes }}
>
  <div class="free-shipping-message__content rte"></div>
  <script type="application/json">
    {
      "beforeHtml": {{ block_settings.before_success_text | json }},
      "successHtml": {{ block_settings.success_text | json }}
    }
  </script>
</free-shipping-message>

{% stylesheet %}
  .free-shipping-message {
    width: 100%;
  }

  .free-shipping-message__content:empty {
    display: none;
  }

  .free-shipping-message__content[data-shipping-state='before'] {
    color: var(--fsm-before-custom-color, inherit);
  }

  .free-shipping-message__content[data-shipping-state='success'] {
    color: var(--fsm-success-custom-color, inherit);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Free shipping message",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "__REMAINING__ in \"Before threshold\" = amount still needed (vs price × qty). Inline richtext only—no <p> or other block tags."
    },
    {
      "type": "number",
      "id": "threshold_amount",
      "label": "Free shipping threshold",
      "info": "Major units (e.g. 75). Multiplied by 100 for cents (best for 2-decimal currencies).",
      "default": 75
    },
    {
      "type": "inline_richtext",
      "id": "before_success_text",
      "label": "Before threshold",
      "default": "Add <strong>__REMAINING__</strong> for free shipping."
    },
    {
      "type": "inline_richtext",
      "id": "success_text",
      "label": "At or above threshold",
      "default": "<strong>Free shipping unlocked.</strong>"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "before_custom_color",
      "label": "Custom color (before threshold)",
      "default": false
    },
    {
      "type": "color",
      "id": "before_text_color",
      "label": "Before threshold text color",
      "alpha": true,
      "default": "#000000",
      "visible_if": "{{ block.settings.before_custom_color }}"
    },
    {
      "type": "checkbox",
      "id": "success_custom_color",
      "label": "Custom color (success message)",
      "default": false
    },
    {
      "type": "color",
      "id": "success_text_color",
      "label": "Success text color",
      "alpha": true,
      "default": "#000000",
      "visible_if": "{{ block.settings.success_custom_color }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Free shipping message",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
