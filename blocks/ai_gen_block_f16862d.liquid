{% doc %}
  @prompt
    generate a row where it has thumbnail on left, has thumbnail width setting, and product title to the left. no font size setting needed. the thumbnail and title source is based on product picker. row should be align center vertically, get rid of title color setting, add custom image picker as optional source, get rid of desktop width setting. should always default to 100%
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .ai-product-row__thumbnail-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.thumbnail_width }}px;
    height: {{ block.settings.thumbnail_width }}px;
  }

  .ai-product-row__thumbnail-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-row__thumbnail-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-row__thumbnail-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-row__title-{{ ai_gen_id }} {
    flex-grow: 1;
    margin: 0;
  }

  .ai-product-row__empty-state-{{ ai_gen_id }} {
    color: #999;
    font-style: italic;
  }

  .product-wrap-link {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 100%;
}

.product-wrap-ai {
    position: relative;
}
{% endstyle %}

<div class="product-wrap-ai">
{% if block.settings.product != blank %}
 <a class="product-wrap-link" href="{{ block.settings.product.url }}"></a>
{% endif %}
  <div
    class="ai-product-row-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="ai-product-row__thumbnail-{{ ai_gen_id }}">
      {% if block.settings.custom_image != blank %}
        <img
          src="{{ block.settings.custom_image | image_url: width: 200 }}"
          alt="{{ block.settings.custom_image.alt | escape }}"
          loading="lazy"
          width="200"
          height="200"
        >
      {% elsif block.settings.product != blank and block.settings.product.featured_image %}
        <img
          src="{{ block.settings.product.featured_image | image_url: width: 200 }}"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          loading="lazy"
          width="200"
          height="200"
        >
      {% else %}
        <div class="ai-product-row__thumbnail-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-row__title-{{ ai_gen_id }}">
      {% if block.settings.product != blank %}
        {{ block.settings.product.title }}
      {% else %}
        <span class="ai-product-row__empty-state-{{ ai_gen_id }}">
          Next, select a product
        </span>
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Product row",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom image",
      "info": "Optional. Overrides product image if set"
    },
    {
      "type": "range",
      "id": "thumbnail_width",
      "label": "Thumbnail width",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Product row"
    }
  ]
}
{% endschema %}
