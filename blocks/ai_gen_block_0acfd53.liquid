{% doc %}
  @prompt
    create text for name with verified icon inline and label with var(--color-link) <svg viewBox="0 0 122.88 116.87" fill="none"><polygon points="61.37 8.24 80.43 0 90.88 17.79 111.15 22.32 109.15 42.85 122.88 58.43 109.2 73.87 111.15 94.55 91 99 80.43 116.87 61.51 108.62 42.45 116.87 32 99.08 11.73 94.55 13.73 74.01 0 58.43 13.68 42.99 11.73 22.32 31.88 17.87 42.45 0 61.37 8.24 61.37 8.24" fill="currentColor"></polygon><path d="M37.92,65c-6.07-6.53,3.25-16.26,10-10.1,2.38,2.17,5.84,5.34,8.24,7.49L74.66,39.66C81.1,33,91.27,42.78,84.91,49.48L61.67,77.2a7.13,7.13,0,0,1-9.9.44C47.83,73.89,42.05,68.5,37.92,65Z" fill="#fff"></path></svg>, label should have its color picker, name can have font weight picker, name and label should have their own fotn size setting, Label style color can be applied to icon
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-verified-name-{{ ai_gen_id }} {
    display: block;
    margin-top: auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-verified-name__wrapper-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-verified-name__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    color: {{ block.settings.name_color }};
    font-weight: {{ block.settings.name_font_weight }};
    margin: 0;
  }

  .ai-verified-name__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.label_color }};
    margin-left: {{ block.settings.label_spacing }}px;
  }

  .ai-verified-name__label-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
  }
{% endstyle %}

<div class="ai-verified-name-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-verified-name__wrapper-{{ ai_gen_id }}">
    <span class="ai-verified-name__text-{{ ai_gen_id }}">{{ block.settings.name }}</span>
    <svg class="ai-verified-name__icon-{{ ai_gen_id }}" viewBox="0 0 122.88 116.87" fill="none">
      <polygon points="61.37 8.24 80.43 0 90.88 17.79 111.15 22.32 109.15 42.85 122.88 58.43 109.2 73.87 111.15 94.55 91 99 80.43 116.87 61.51 108.62 42.45 116.87 32 99.08 11.73 94.55 13.73 74.01 0 58.43 13.68 42.99 11.73 22.32 31.88 17.87 42.45 0 61.37 8.24 61.37 8.24" fill="currentColor"></polygon>
      <path d="M37.92,65c-6.07-6.53,3.25-16.26,10-10.1,2.38,2.17,5.84,5.34,8.24,7.49L74.66,39.66C81.1,33,91.27,42.78,84.91,49.48L61.67,77.2a7.13,7.13,0,0,1-9.9.44C47.83,73.89,42.05,68.5,37.92,65Z" fill="#fff"></path>
    </svg>
  </div>
  {% if block.settings.label != blank %}
    <div class="ai-verified-name__label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Verified name",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "John Doe"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label"
    },
    {
      "type": "header",
      "content": "Name style"
    },
    {
      "type": "range",
      "id": "name_font_size",
      "label": "Font size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "name_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Spacing from name",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Label style"
    },
    {
      "type": "range",
      "id": "label_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Color",
      "default": "#9bbf6e"
    },
    {
      "type": "range",
      "id": "label_spacing",
      "label": "Spacing from name",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Verified name"
    }
  ]
}
{% endschema %}
